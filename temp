#include <DHT.h>
#define DHTPIN 2
dht(DHTPIN,DHT11);
void setup()
{
Serial.begin(115200); 
delay(10);
dht.begin();
}
void loop()
{
float h = dht.readHumidity(); // Reading Humidity float t = dht.readTemperature();
Reading Temperature Serial.print("Temperature: "); // Print to serial monitor Serial.print(t);
Serial.print(" degrees Celcius, Humidity: "); Serial.print(h);
Serial.println(""); delay(5000);
}
